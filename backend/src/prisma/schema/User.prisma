model User {
    id        Int        @id @default(autoincrement())
    name      String
    email     String     @unique
    password  String
    role      UserRole
    status    UserStatus
    createdAt DateTime   @default(now())

    vendorProfile  VendorProfile?
    orders         Order[]
    posts          CommunityPost[]
    bookings       Booking[]
    plantTrackings PlantTracking[]
}
