model VendorProfile {
    id           Int    @id @default(autoincrement())
    userId       Int    @unique
    farmName     String
    farmLocation String

    user           User                 @relation(fields: [userId], references: [id])
    produces       Produce[]
    rentalSpaces   RentalSpace[]
    orders         Order[]
    certifications SustainabilityCert[]
}
