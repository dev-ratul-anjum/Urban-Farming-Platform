model Booking {
    id Int @id @default(autoincrement())

    userId Int
    user   User @relation(fields: [userId], references: [id])

    rentalSpaceId Int
    rentalSpace   RentalSpace @relation(fields: [rentalSpaceId], references: [id])

    startDate DateTime
    endDate   DateTime

    totalAmount Float
    status      BookingStatus @default(PENDING) // Pending, Active, Completed, Cancelled

    createdAt DateTime @default(now())
}
